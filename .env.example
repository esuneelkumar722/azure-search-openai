# =============================================================================
# Environment Variables Example — azure-search-openai
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# For Terraform-based deployments most values come from `terraform output`.
# Run: cd infra/terraform && terraform output
#
# DO NOT commit .env — it is gitignored (may contain secrets after auth setup)
# =============================================================================

# -----------------------------------------------------------------------------
# Azure Core
# -----------------------------------------------------------------------------
AZURE_TENANT_ID="<your-tenant-id>"
AZURE_AUTH_TENANT_ID="<your-tenant-id>"          # Same as AZURE_TENANT_ID unless using guest tenant
AZURE_SUBSCRIPTION_ID="<your-subscription-id>"
AZURE_RESOURCE_GROUP="rg-<env>-openai-rag"
AZURE_PRINCIPAL_ID="<your-user-object-id>"             # az ad signed-in-user show --query id -o tsv

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
AZURE_STORAGE_ACCOUNT="<from: terraform output azure_storage_account>"
AZURE_STORAGE_CONTAINER="content"
AZURE_STORAGE_RESOURCE_GROUP="<from: terraform output azure_resource_group>"
AZURE_IMAGESTORAGE_CONTAINER="images"            # Container for extracted PDF images (multimodal)
AZURE_USERSTORAGE_ACCOUNT=""                     # Only needed when use_user_upload=true
AZURE_USERSTORAGE_CONTAINER="user-content"
AZURE_CLOUD_INGESTION_STORAGE_ACCOUNT="<same as AZURE_STORAGE_ACCOUNT>"

# -----------------------------------------------------------------------------
# Azure AI Search
# -----------------------------------------------------------------------------
AZURE_SEARCH_SERVICE="<from: terraform output azure_search_service>"
AZURE_SEARCH_INDEX="gptkbindex"
AZURE_SEARCH_SERVICE_RESOURCE_GROUP="<from: terraform output azure_search_service_resource_group>"
AZURE_SEARCH_FIELD_NAME_EMBEDDING="embedding3"
AZURE_SEARCH_SEMANTIC_RANKER="free"
AZURE_SEARCH_KNOWLEDGEBASE_NAME="gptkbindex-agent-upgrade"

# -----------------------------------------------------------------------------
# Azure OpenAI
# -----------------------------------------------------------------------------
OPENAI_HOST="azure"
AZURE_OPENAI_SERVICE="<from: terraform output azure_openai_service>"
AZURE_OPENAI_ENDPOINT="https://<openai-service-name>.openai.azure.com/"
AZURE_OPENAI_CHATGPT_MODEL="gpt-4.1-mini"
AZURE_OPENAI_CHATGPT_DEPLOYMENT="gpt-4.1-mini"
AZURE_OPENAI_EMB_MODEL_NAME="text-embedding-3-large"
AZURE_OPENAI_EMB_DEPLOYMENT="text-embedding-3-large"
AZURE_OPENAI_EMB_DIMENSIONS="3072"
AZURE_OPENAI_KNOWLEDGEBASE_MODEL="gpt-4.1-mini"
AZURE_OPENAI_KNOWLEDGEBASE_DEPLOYMENT="knowledgebase"
AZURE_OPENAI_REASONING_EFFORT="medium"

# -----------------------------------------------------------------------------
# Document Intelligence
# -----------------------------------------------------------------------------
AZURE_DOCUMENTINTELLIGENCE_SERVICE="<from: terraform output azure_documentintelligence_service>"

# -----------------------------------------------------------------------------
# Azure Vision (multimodal — image extraction from PDFs)
# -----------------------------------------------------------------------------
AZURE_VISION_ENDPOINT="<from: terraform output azure_vision_endpoint>"

# -----------------------------------------------------------------------------
# Cosmos DB (chat history)
# -----------------------------------------------------------------------------
AZURE_COSMOSDB_ACCOUNT="<from: terraform output azure_cosmosdb_account>"
AZURE_CHAT_HISTORY_DATABASE="chat-database"
AZURE_CHAT_HISTORY_CONTAINER="chat-history-v2"
AZURE_CHAT_HISTORY_VERSION="cosmosdb-v2"

# -----------------------------------------------------------------------------
# Container App (needed by auth_update.py to register redirect URIs)
# -----------------------------------------------------------------------------
BACKEND_URI="https://<from: terraform output backend_uri>"

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
AZURE_USE_AUTHENTICATION="false"              # Set true after running scripts/auth_init.py
AZURE_ENFORCE_ACCESS_CONTROL="false"          # Requires use_authentication=true
AZURE_ENABLE_GLOBAL_DOCUMENT_ACCESS="true"
AZURE_ENABLE_UNAUTHENTICATED_ACCESS="true"
USE_VECTORS="true"
USE_MULTIMODAL="true"
USE_USER_UPLOAD="false"                       # Requires use_authentication=true
USE_AGENTIC_KNOWLEDGEBASE="true"
USE_FEATURE_INT_VECTORIZATION="true"
USE_CLOUD_INGESTION="false"
USE_CHAT_HISTORY_COSMOS="true"

# -----------------------------------------------------------------------------
# Auth App IDs — filled automatically by scripts/auth_init.py
# Only needed when AZURE_USE_AUTHENTICATION=true
# Requires Application Administrator role in Entra ID tenant
# -----------------------------------------------------------------------------
AZURE_SERVER_APP_ID=""
AZURE_SERVER_APP_SECRET=""
AZURE_CLIENT_APP_ID=""
AZURE_CLIENT_APP_SECRET=""
